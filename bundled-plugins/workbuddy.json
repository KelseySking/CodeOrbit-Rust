{
  "schema_version": "2.0",
  "source": {
    "key": "workbuddy",
    "display_name": "WorkBuddy",
    "icon_name": "workbuddy",
    "permission_response_style": "claude-style"
  },
  "detection": {
    "process_names": ["workbuddy", "work-buddy"],
    "path_patterns": ["*workbuddy*"],
    "priority": 1000
  },
  "hook_installation": {
    "format": "claude-matcher",
    "config_path": "~/.workbuddy/settings.json",
    "events": [
      "UserPromptSubmit",
      "PreToolUse",
      "PostToolUse",
      "PostToolUseFailure",
      "PermissionRequest",
      "Stop",
      "SubagentStart",
      "SubagentStop",
      "SessionStart",
      "SessionEnd",
      "Notification",
      "PreCompact"
    ],
    "timeout_seconds": 120
  }
}
