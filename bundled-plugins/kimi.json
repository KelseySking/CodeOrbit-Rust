{
  "schema_version": "2.0",
  "source": {
    "key": "kimi",
    "display_name": "Kimi Code",
    "icon_name": "kimi",
    "permission_response_style": "claude-style"
  },
  "detection": {
    "process_names": ["kimi", "kimi-code"],
    "path_patterns": ["*kimi*"],
    "priority": 1000
  },
  "hook_installation": {
    "format": "nested",
    "config_path": "~/.kimi/hooks.json",
    "events": [
      "PreToolUse",
      "PostToolUse",
      "UserPromptSubmit",
      "SessionStart",
      "SessionEnd",
      "Stop"
    ],
    "timeout_seconds": 10
  }
}
